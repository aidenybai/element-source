{
  "name": "example-capacitor-svelte",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "cap:init": "cap init 'Element Source Svelte' com.elementsource.svelte --web-dir dist",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "mobile:ios": "pnpm build && pnpm cap:sync && pnpm cap:open:ios",
    "mobile:android": "pnpm build && pnpm cap:sync && pnpm cap:open:android"
  },
  "dependencies": {
    "element-source": "workspace:*",
    "svelte": "^5.53.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "typescript": "^5.7.0",
    "vite": "^6.3.0"
  }
}
